@model IEnumerable<CinemaTicket.Application.DTOs.ShowtimeDto>
@{
    ViewData["Title"] = "Quản lý lịch chiếu";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Quản lý lịch chiếu</h2>
        <a asp-action="Create" class="btn btn-success">+ Thêm suất chiếu</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <form method="get" class="row g-2 mb-4">
        <div class="col-md-3">
            <select name="movieId" class="form-select">
                <option value="">-- Tất cả phim --</option>
                @foreach (var movie in ViewBag.Movies)
                {
                    <option value="@movie.Id" selected="@(ViewBag.MovieId == movie.Id)">@movie.Title</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <select name="cinemaId" class="form-select">
                <option value="">-- Tất cả rạp --</option>
                @foreach (var cinema in ViewBag.Cinemas)
                {
                    <option value="@cinema.Id" selected="@(ViewBag.CinemaId == cinema.Id)">@cinema.Name</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <input type="date" name="date" value="@ViewBag.Date" class="form-control" />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary w-100">Lọc</button>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Không có suất chiếu nào.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Phim</th>
                        <th>Rạp / Phòng</th>
                        <th>Giờ chiếu</th>
                        <th>Định dạng</th>
                        <th>Giá vé</th>
                        <th>Ghế trống</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td><strong>@s.MovieTitle</strong></td>
                            <td>@s.CinemaName<br /><small class="text-muted">@s.HallName</small></td>
                            <td>
                                @s.StartTime.ToString("dd/MM/yyyy")<br />
                                <strong>@s.StartTime.ToString("HH:mm")</strong> — @s.EndTime.ToString("HH:mm")
                            </td>
                            <td><span class="badge bg-secondary">@s.Format</span></td>
                            <td>@s.BasePrice.ToString("N0") đ</td>
                            <td>
                                <span class="badge @(s.AvailableSeats > 10 ? "bg-success" : s.AvailableSeats > 0 ? "bg-warning" : "bg-danger")">
                                    @s.AvailableSeats / @s.TotalSeats
                                </span>
                            </td>
                            <td>
                                <form asp-action="Delete" asp-route-id="@s.Id" method="post"
                                      onsubmit="return confirm('Xóa suất chiếu này?')">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>