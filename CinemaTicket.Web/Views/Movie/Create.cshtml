@model CinemaTicket.Application.DTOs.CreateMovieDto
@{
    ViewData["Title"] = "Thêm phim mới";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">Thêm phim mới</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label asp-for="Title" class="form-label">Tên phim *</label>
                                <input asp-for="Title" class="form-control" />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="Rating" class="form-label">Phân loại *</label>
                                <select asp-for="Rating" class="form-select">
                                    <option value="P">P - Mọi lứa tuổi</option>
                                    <option value="C13">C13 - Trên 13 tuổi</option>
                                    <option value="C16">C16 - Trên 16 tuổi</option>
                                    <option value="C18">C18 - Trên 18 tuổi</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="OriginalTitle" class="form-label">Tên gốc</label>
                            <input asp-for="OriginalTitle" class="form-control" />
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="Duration" class="form-label">Thời lượng (phút) *</label>
                                <input asp-for="Duration" type="number" class="form-control" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="ReleaseDate" class="form-label">Ngày khởi chiếu *</label>
                                <input asp-for="ReleaseDate" type="date" class="form-control" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="EndDate" class="form-label">Ngày kết thúc</label>
                                <input asp-for="EndDate" type="date" class="form-control" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Director" class="form-label">Đạo diễn</label>
                                <input asp-for="Director" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Cast" class="form-label">Diễn viên</label>
                                <input asp-for="Cast" class="form-control" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TrailerUrl" class="form-label">Link Trailer YouTube</label>
                            <input asp-for="TrailerUrl" class="form-control" placeholder="https://youtube.com/..." />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Mô tả nội dung</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Thể loại</label>
                            <div class="row">
                                @foreach (var genre in ViewBag.Genres)
                                {
                                    <div class="col-md-3">
                                        <div class="form-check">
                                            <input type="checkbox" name="GenreIds" value="@genre.Id"
                                                   class="form-check-input" id="genre_@genre.Id" />
                                            <label class="form-check-label" for="genre_@genre.Id">@genre.Name</label>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Poster" class="form-label">Poster phim</label>
                            <input asp-for="Poster" type="file" class="form-control" accept="image/*" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">Thêm phim</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}