@model IEnumerable<CinemaTicket.Application.DTOs.CinemaDto>
@{
    ViewData["Title"] = "Quản lý rạp chiếu";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Quản lý rạp chiếu</h2>
        <a asp-action="Create" class="btn btn-success">+ Thêm rạp</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var cinema in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">🎬 @cinema.Name</h5>
                        <p class="text-muted mb-1">📍 @cinema.Address</p>
                        @if (!string.IsNullOrEmpty(cinema.Phone))
                        {
                            <p class="text-muted mb-1">📞 @cinema.Phone</p>
                        }
                        @if (!string.IsNullOrEmpty(cinema.City))
                        {
                            <p class="text-muted mb-2">🏙️ @cinema.City</p>
                        }
                        <span class="badge bg-info">@cinema.TotalHalls phòng chiếu</span>
                    </div>
                    <div class="card-footer d-flex gap-2">
                        <a asp-action="Halls" asp-route-id="@cinema.Id"
                           class="btn btn-primary btn-sm flex-grow-1">Xem phòng chiếu</a>
                        <form asp-action="Delete" asp-route-id="@cinema.Id" method="post"
                              onsubmit="return confirm('Xóa rạp này?')">
                            <button type="submit" class="btn btn-outline-danger btn-sm">Xóa</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>