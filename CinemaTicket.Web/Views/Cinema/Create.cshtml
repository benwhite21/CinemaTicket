@model CinemaTicket.Application.DTOs.CreateCinemaDto
@{
    ViewData["Title"] = "Thêm rạp mới";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">Thêm rạp mới</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Tên rạp *</label>
                            <input asp-for="Name" class="form-control" placeholder="CGV Vincom..." />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Address" class="form-label">Địa chỉ *</label>
                            <input asp-for="Address" class="form-control" placeholder="191 Bà Triệu..." />
                        </div>
                        <div class="mb-3">
                            <label asp-for="City" class="form-label">Thành phố</label>
                            <input asp-for="City" class="form-control" placeholder="Hà Nội..." />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label">Số điện thoại</label>
                            <input asp-for="Phone" class="form-control" placeholder="024 3974 3333" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">Thêm rạp</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>