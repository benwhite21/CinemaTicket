@model CinemaTicket.Application.DTOs.CreateHallDto
@{
    ViewData["Title"] = "Thêm phòng chiếu";
    var cinema = ViewBag.Cinema as CinemaTicket.Application.DTOs.CinemaDto;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">Thêm phòng chiếu — @cinema?.Name</h4>
                </div>
                <div class="card-body">
                    <form asp-action="CreateHall" method="post">
                        <input asp-for="CinemaId" type="hidden" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Tên phòng *</label>
                            <input asp-for="Name" class="form-control" placeholder="Phòng 1, IMAX..." />
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Rows" class="form-label">Số hàng ghế *</label>
                                <input asp-for="Rows" type="number" class="form-control" min="1" max="20" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Columns" class="form-label">Số ghế mỗi hàng *</label>
                                <input asp-for="Columns" type="number" class="form-control" min="1" max="20" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="VipRowsFromBack" class="form-label">Số hàng VIP (từ cuối)</label>
                            <input asp-for="VipRowsFromBack" type="number" class="form-control" min="0" max="5" />
                            <small class="text-muted">Các hàng cuối sẽ được đặt là ghế VIP</small>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">Tạo phòng chiếu</button>
                            <a asp-action="Halls" asp-route-id="@Model.CinemaId"
                               class="btn btn-outline-secondary">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>